# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── Blizzard / Battle.net OAuth & API ───────────────────────────────────────
BLIZZARD_CLIENT_ID=your-client-id
BLIZZARD_CLIENT_SECRET=your-client-secret
# Region: us | eu | kr | tw
BLIZZARD_REGION=us
# Realm slug (e.g. ragnaros)
BLIZZARD_REALM_SLUG=ragnaros
# Guild name slug (e.g. the-burning-seagull)
BLIZZARD_GUILD_SLUG=the-burning-seagull
# Locale (e.g. en_US, es_MX)
BLIZZARD_LOCALE=en_US

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url
